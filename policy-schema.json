{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/atgreen/mcp-policy-guard/policy-schema",
  "title": "mcp-policy-guard policy",
  "description": "Policy file schema for mcp-policy-guard.",
  "type": "object",
  "required": ["version"],
  "anyOf": [
    { "required": ["rules"] },
    { "required": ["agent_card"] }
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Must be 1."
    },
    "agent_card": { "$ref": "#/$defs/agent_card" },
    "defaults": { "$ref": "#/$defs/defaults" },
    "identity": { "$ref": "#/$defs/identity" },
    "approval": { "$ref": "#/$defs/approval_config" },
    "escalation": { "$ref": "#/$defs/escalation_config" },
    "audit": { "$ref": "#/$defs/audit_config" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" },
      "description": "Ordered list of policy rules. First match wins."
    },
    "rate_limits": {
      "type": "array",
      "items": { "$ref": "#/$defs/rate_limit" },
      "description": "Rate limiting rules. Applied before rule matching."
    },
    "content_filters": {
      "type": "array",
      "items": { "$ref": "#/$defs/content_filter" },
      "description": "Content inspection rules. Applied after rule matching."
    }
  },

  "$defs": {

    "agent_card": {
      "type": "object",
      "description": "FINOS Agent Card source. Exactly one of path, url, or configmap must be set.",
      "oneOf": [
        { "required": ["path"] },
        { "required": ["url"] },
        { "required": ["configmap"] }
      ],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "configmap": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$" },
        "watch": { "type": "boolean", "default": false }
      }
    },

    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string", "enum": ["deny", "allow", "audit_only"], "default": "deny" },
        "audit": { "type": "boolean", "default": true },
        "deny_message": { "type": "string", "default": "Tool call not permitted by policy" }
      }
    },

    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/identity_source" }
        }
      }
    },

    "identity_source": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        { "properties": { "type": { "const": "jwt_claim" }, "claim": { "type": "string" }, "header": { "type": "string" } }, "required": ["type", "claim"] },
        { "properties": { "type": { "const": "header" }, "header": { "type": "string" } }, "required": ["type", "header"] },
        { "properties": { "type": { "const": "client_cert" }, "field": { "type": "string", "enum": ["cn", "san_dns", "san_uri"] } }, "required": ["type", "field"] },
        { "properties": { "type": { "const": "static" }, "value": { "type": "string" } }, "required": ["type", "value"] }
      ]
    },

    "approval_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channels"],
      "properties": {
        "channels": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/approval_channel" } },
        "timeout": { "$ref": "#/$defs/duration" },
        "on_timeout": { "type": "string", "enum": ["reject", "escalate", "allow"], "default": "reject" },
        "escalate_on_timeout_to": { "type": "string", "description": "Escalation channel name when on_timeout is 'escalate'." }
      }
    },

    "approval_channel": {
      "type": "object",
      "required": ["name", "type"],
      "oneOf": [
        {
          "properties": {
            "name": { "type": "string" }, "type": { "const": "terminal" },
            "show_args": { "type": "boolean" }, "show_context": { "type": "boolean" },
            "fallback": { "type": "string" }
          }, "required": ["name", "type"]
        },
        {
          "properties": {
            "name": { "type": "string" }, "type": { "const": "webhook" },
            "endpoint": { "type": "string", "format": "uri" },
            "method": { "type": "string", "enum": ["POST", "PUT"] },
            "headers": { "type": "object", "additionalProperties": { "type": "string" } },
            "callback_mode": { "type": "string", "enum": ["callback", "poll"] },
            "poll_interval": { "$ref": "#/$defs/duration" }
          }, "required": ["name", "type", "endpoint"]
        },
        {
          "properties": {
            "name": { "type": "string" }, "type": { "const": "slack" },
            "webhook_url": { "type": "string", "format": "uri" },
            "channel": { "type": "string" },
            "callback_url": { "type": "string", "format": "uri" }
          }, "required": ["name", "type", "webhook_url"]
        }
      ]
    },

    "escalation_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channels"],
      "properties": {
        "channels": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/escalation_channel" } }
      }
    },

    "escalation_channel": {
      "type": "object",
      "required": ["name", "type"],
      "oneOf": [
        {
          "properties": {
            "name": { "type": "string" }, "type": { "const": "webhook" },
            "endpoint": { "type": "string", "format": "uri" },
            "method": { "type": "string", "enum": ["POST", "PUT"] },
            "headers": { "type": "object", "additionalProperties": { "type": "string" } },
            "payload_template": { "type": "string" }
          }, "required": ["name", "type", "endpoint"]
        },
        {
          "properties": {
            "name": { "type": "string" }, "type": { "const": "email" },
            "smtp_host": { "type": "string" }, "smtp_port": { "type": "integer" },
            "from": { "type": "string" },
            "to": { "type": "array", "items": { "type": "string", "format": "email" }, "minItems": 1 }
          }, "required": ["name", "type", "smtp_host", "from", "to"]
        },
        {
          "properties": {
            "name": { "type": "string" }, "type": { "const": "pagerduty" },
            "routing_key": { "type": "string" },
            "severity": { "type": "string", "enum": ["critical", "error", "warning", "info"] }
          }, "required": ["name", "type", "routing_key"]
        }
      ]
    },

    "audit_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outputs"],
      "properties": {
        "outputs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/audit_output" } },
        "include": { "$ref": "#/$defs/audit_include" },
        "redaction": { "$ref": "#/$defs/audit_redaction" }
      }
    },

    "audit_output": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        { "properties": { "type": { "const": "stdout" }, "format": { "type": "string", "enum": ["json", "text"] } }, "required": ["type"] },
        { "properties": { "type": { "const": "file" }, "path": { "type": "string" }, "format": { "type": "string", "enum": ["jsonl"] }, "rotate": { "type": "object", "additionalProperties": false, "properties": { "max_size_mb": { "type": "integer", "minimum": 1 }, "max_files": { "type": "integer", "minimum": 1 } } } }, "required": ["type", "path"] },
        { "properties": { "type": { "const": "webhook" }, "endpoint": { "type": "string", "format": "uri" }, "method": { "type": "string", "enum": ["POST", "PUT"] }, "headers": { "type": "object", "additionalProperties": { "type": "string" } }, "batch": { "type": "object", "additionalProperties": false, "properties": { "max_size": { "type": "integer", "minimum": 1 }, "flush_interval": { "$ref": "#/$defs/duration" } } } }, "required": ["type", "endpoint"] },
        { "properties": { "type": { "const": "otel" }, "endpoint": { "type": "string" }, "protocol": { "type": "string", "enum": ["grpc", "http"], "default": "grpc" } }, "required": ["type", "endpoint"] }
      ]
    },

    "audit_include": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool_name": { "type": "boolean" }, "tool_arguments": { "type": "boolean" },
        "tool_response": { "type": "boolean" }, "agent_identity": { "type": "boolean" },
        "timestamp": { "type": "boolean" }, "request_id": { "type": "boolean" },
        "policy_decision": { "type": "boolean" }, "approval_metadata": { "type": "boolean" },
        "latency": { "type": "boolean" }
      }
    },

    "audit_redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fields": { "type": "array", "items": { "type": "string" } },
        "patterns": { "type": "array", "items": { "$ref": "#/$defs/redaction_pattern" } }
      }
    },

    "redaction_pattern": {
      "type": "object",
      "required": ["name", "regex", "replacement"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "regex": { "type": "string", "format": "regex" },
        "replacement": { "type": "string" }
      }
    },

    "rule": {
      "type": "object",
      "required": ["name", "match", "action"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "match": { "$ref": "#/$defs/rule_match" },
        "action": { "type": "string", "enum": ["allow", "deny", "require_approval", "audit_only", "mutate"] },
        "deny_message": { "type": "string" },
        "audit": { "type": "boolean" },
        "approval": { "$ref": "#/$defs/rule_approval" },
        "escalate": { "$ref": "#/$defs/rule_escalation" },
        "mutate": { "$ref": "#/$defs/rule_mutate" }
      },
      "if": { "properties": { "action": { "const": "require_approval" } } },
      "then": { "required": ["name", "match", "action", "approval"] }
    },

    "rule_match": {
      "type": "object",
      "required": ["tools"],
      "additionalProperties": false,
      "properties": {
        "tools": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "agent": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "identity": { "type": "string" } }
        },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cel"],
          "properties": { "cel": { "type": "string" } }
        },
        "time_window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["active_cron"],
          "properties": {
            "active_cron": { "type": "string", "description": "Cron expression defining when this rule is active." },
            "timezone": { "type": "string", "description": "IANA timezone name, e.g. America/New_York." }
          }
        }
      }
    },

    "rule_approval": {
      "type": "object",
      "required": ["channel"],
      "additionalProperties": false,
      "properties": {
        "channel": { "type": "string" },
        "timeout": { "$ref": "#/$defs/duration" },
        "on_timeout": { "type": "string", "enum": ["reject", "escalate", "allow"] },
        "message": { "type": "string" }
      }
    },

    "rule_escalation": {
      "type": "object",
      "required": ["channel", "trigger_name"],
      "additionalProperties": false,
      "properties": {
        "channel": { "type": "string" },
        "trigger_name": { "type": "string" }
      }
    },

    "rate_limit": {
      "type": "object",
      "required": ["name", "match", "limit"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "match": {
          "type": "object",
          "required": ["tools"],
          "additionalProperties": false,
          "properties": { "tools": { "type": "array", "minItems": 1, "items": { "type": "string" } } }
        },
        "limit": {
          "type": "object",
          "required": ["requests", "window"],
          "additionalProperties": false,
          "properties": {
            "requests": { "type": "integer", "minimum": 1 },
            "window": { "$ref": "#/$defs/duration" }
          }
        },
        "key": { "type": "string", "enum": ["agent", "tool", "global"], "default": "agent" },
        "on_exceed": { "type": "string", "enum": ["deny", "escalate"], "default": "deny" },
        "deny_message": { "type": "string" },
        "escalate": { "$ref": "#/$defs/rule_escalation" }
      }
    },

    "content_filter": {
      "type": "object",
      "required": ["name", "direction", "match", "patterns", "action"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "direction": { "type": "string", "enum": ["request", "response", "both"] },
        "match": {
          "type": "object",
          "required": ["tools"],
          "additionalProperties": false,
          "properties": { "tools": { "type": "array", "minItems": 1, "items": { "type": "string" } } }
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "regex"],
            "additionalProperties": false,
            "properties": { "name": { "type": "string" }, "regex": { "type": "string", "format": "regex" } }
          }
        },
        "action": { "type": "string", "enum": ["block", "redact", "flag"] },
        "block_message": { "type": "string" },
        "audit": { "type": "boolean" },
        "escalate": { "$ref": "#/$defs/rule_escalation" }
      }
    },

    "rule_mutate": {
      "type": "object",
      "required": ["arguments"],
      "additionalProperties": false,
      "properties": {
        "arguments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["op", "path"],
            "additionalProperties": false,
            "properties": {
              "op": { "type": "string", "enum": ["add", "remove", "replace"] },
              "path": { "type": "string", "description": "JSON Pointer (RFC 6901) to the field." },
              "value": { "description": "Static value for add/replace." },
              "cel": { "type": "string", "description": "CEL expression computing the value." }
            }
          }
        }
      }
    },

    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$"
    }
  }
}
