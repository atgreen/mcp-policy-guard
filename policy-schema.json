{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mcp-policy-guard/policy/v0.1",
  "title": "mcp-policy-guard v0.1 policy",
  "description": "Policy file schema for mcp-policy-guard v0.1. This schema defines exactly the fields supported by the v0.1 binary. Future versions will ship updated schemas.",
  "type": "object",
  "required": ["version"],
  "anyOf": [
    { "required": ["rules"] },
    { "required": ["agent_card"] }
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Must be 1."
    },
    "agent_card": {
      "$ref": "#/$defs/agent_card"
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "approval": {
      "$ref": "#/$defs/approval_config"
    },
    "audit": {
      "$ref": "#/$defs/audit_config"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" },
      "description": "Ordered list of policy rules. First match wins."
    }
  },

  "$defs": {

    "agent_card": {
      "type": "object",
      "description": "FINOS Agent Card source. Exactly one of path, url, or configmap must be set.",
      "oneOf": [
        { "required": ["path"] },
        { "required": ["url"] },
        { "required": ["configmap"] }
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Local file path to agent card JSON."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL to fetch agent card JSON."
        },
        "configmap": {
          "type": "string",
          "pattern": "^[a-z0-9-]+/[a-z0-9-]+$",
          "description": "Kubernetes ConfigMap reference as namespace/name."
        },
        "watch": {
          "type": "boolean",
          "default": false,
          "description": "Re-read agent card on change (file or ConfigMap)."
        }
      }
    },

    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": ["deny", "allow", "audit_only"],
          "default": "deny",
          "description": "Action for tool calls that match no explicit rule."
        },
        "audit": {
          "type": "boolean",
          "default": true,
          "description": "Log every tool call regardless of action."
        },
        "deny_message": {
          "type": "string",
          "default": "Tool call not permitted by policy",
          "description": "Error message returned to client on default deny."
        }
      }
    },

    "identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/identity_source" },
          "description": "Ordered list of identity sources. First match wins."
        }
      },
      "required": ["sources"]
    },

    "identity_source": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": {
            "type": { "const": "jwt_claim" },
            "claim": { "type": "string" },
            "header": { "type": "string", "default": "Authorization" }
          },
          "required": ["type", "claim"]
        },
        {
          "properties": {
            "type": { "const": "header" },
            "header": { "type": "string" }
          },
          "required": ["type", "header"]
        },
        {
          "properties": {
            "type": { "const": "client_cert" },
            "field": { "type": "string", "enum": ["cn", "san_dns", "san_uri"] }
          },
          "required": ["type", "field"]
        },
        {
          "properties": {
            "type": { "const": "static" },
            "value": { "type": "string" }
          },
          "required": ["type", "value"]
        }
      ]
    },

    "approval_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "channels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/approval_channel" },
          "description": "Named approval channels referenced by rules."
        },
        "timeout": {
          "$ref": "#/$defs/duration",
          "default": "300s",
          "description": "Default max wait time for approval."
        },
        "on_timeout": {
          "type": "string",
          "enum": ["reject", "allow"],
          "default": "reject",
          "description": "Action when approval times out. 'escalate' added in v0.2."
        }
      },
      "required": ["channels"]
    },

    "approval_channel": {
      "type": "object",
      "required": ["name", "type"],
      "oneOf": [
        {
          "properties": {
            "name": { "type": "string" },
            "type": { "const": "terminal" },
            "show_args": { "type": "boolean", "default": true },
            "show_context": { "type": "boolean", "default": false },
            "fallback": {
              "type": "string",
              "description": "Channel name to fall back to if /dev/tty is unavailable."
            }
          },
          "required": ["name", "type"]
        },
        {
          "properties": {
            "name": { "type": "string" },
            "type": { "const": "webhook" },
            "endpoint": { "type": "string", "format": "uri" },
            "method": { "type": "string", "enum": ["POST", "PUT"], "default": "POST" },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "callback_mode": {
              "type": "string",
              "enum": ["callback", "poll"],
              "default": "callback"
            },
            "poll_interval": {
              "$ref": "#/$defs/duration",
              "default": "5s"
            }
          },
          "required": ["name", "type", "endpoint"]
        }
      ]
    },

    "audit_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/audit_output" }
        },
        "include": {
          "$ref": "#/$defs/audit_include"
        },
        "redaction": {
          "$ref": "#/$defs/audit_redaction"
        }
      },
      "required": ["outputs"]
    },

    "audit_output": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": {
            "type": { "const": "stdout" },
            "format": { "type": "string", "enum": ["json", "text"], "default": "json" }
          },
          "required": ["type"]
        },
        {
          "properties": {
            "type": { "const": "file" },
            "path": { "type": "string" },
            "format": { "type": "string", "enum": ["jsonl"], "default": "jsonl" },
            "rotate": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "max_size_mb": { "type": "integer", "minimum": 1 },
                "max_files": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "required": ["type", "path"]
        },
        {
          "properties": {
            "type": { "const": "webhook" },
            "endpoint": { "type": "string", "format": "uri" },
            "method": { "type": "string", "enum": ["POST", "PUT"], "default": "POST" },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "batch": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "max_size": { "type": "integer", "minimum": 1, "default": 100 },
                "flush_interval": { "$ref": "#/$defs/duration", "default": "5s" }
              }
            }
          },
          "required": ["type", "endpoint"]
        }
      ]
    },

    "audit_include": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool_name": { "type": "boolean", "default": true },
        "tool_arguments": { "type": "boolean", "default": true },
        "tool_response": { "type": "boolean", "default": true },
        "agent_identity": { "type": "boolean", "default": true },
        "timestamp": { "type": "boolean", "default": true },
        "request_id": { "type": "boolean", "default": true },
        "policy_decision": { "type": "boolean", "default": true },
        "approval_metadata": { "type": "boolean", "default": true },
        "latency": { "type": "boolean", "default": true }
      }
    },

    "audit_redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "JSON field names to redact from tool arguments/responses."
        },
        "patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/redaction_pattern" }
        }
      }
    },

    "redaction_pattern": {
      "type": "object",
      "required": ["name", "regex", "replacement"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "regex": { "type": "string", "format": "regex" },
        "replacement": { "type": "string" }
      }
    },

    "rule": {
      "type": "object",
      "required": ["name", "match", "action"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique rule name for audit trail and error messages."
        },
        "description": {
          "type": "string"
        },
        "match": {
          "$ref": "#/$defs/rule_match"
        },
        "action": {
          "type": "string",
          "enum": ["allow", "deny", "require_approval", "audit_only"]
        },
        "deny_message": {
          "type": "string",
          "description": "Custom error message for deny actions."
        },
        "audit": {
          "type": "boolean",
          "description": "Override default audit setting for this rule."
        },
        "approval": {
          "$ref": "#/$defs/rule_approval",
          "description": "Required when action is 'require_approval'."
        }
      },
      "if": {
        "properties": { "action": { "const": "require_approval" } }
      },
      "then": {
        "required": ["name", "match", "action", "approval"]
      }
    },

    "rule_match": {
      "type": "object",
      "required": ["tools"],
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Glob patterns matching tool names."
        },
        "agent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "identity": {
              "type": "string",
              "description": "Glob pattern matching agent identity."
            }
          }
        }
      }
    },

    "rule_approval": {
      "type": "object",
      "required": ["channel"],
      "additionalProperties": false,
      "properties": {
        "channel": {
          "type": "string",
          "description": "References approval.channels[].name."
        },
        "timeout": {
          "$ref": "#/$defs/duration",
          "description": "Override global approval timeout."
        },
        "on_timeout": {
          "type": "string",
          "enum": ["reject", "allow"],
          "description": "Override global on_timeout."
        },
        "message": {
          "type": "string",
          "description": "Message shown to the approver."
        }
      }
    },

    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "description": "Duration string, e.g. '300s', '5m', '100ms'."
    }
  }
}
